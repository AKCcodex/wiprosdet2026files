        driver.findElement(By.xpath("/html/body/div[2]/div[3]/div/nav/button[3]/span[2]")).click();
        Thread.sleep(2000);

  
     



        driver.findElement(By.xpath("/html/body/div[2]/div[3]/div/div/div[3]/div/div/form/div[1]/div[1]/div/div[1]/input")).sendKeys("Dubai");
        Thread.sleep(2000);
        driver.findElement(By.xpath("/html/body/div[2]/div[3]/div/div/div[3]/div/div/form/div[1]/div[1]/div/div[2]/div[2]/div/div[2]/div[2]")).click();
        Thread.sleep(1000);



        driver.findElement(By.xpath("//*[@id=\"arrival_airport_input\"]")).sendKeys("London");
        Thread.sleep(2000);
        driver.findElement(By.xpath("/html/body/div[2]/div[3]/div/div/div[3]/div/div/form/div[1]/div[2]/div/div[2]/div[2]/div/div[2]/div[2]")).click();
