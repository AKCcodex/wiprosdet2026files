package testCases;
import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.support.ui.Select;
public class TC_phptravels {
	public static void main(String[] args) throws InterruptedException {

        WebDriver driver = new ChromeDriver();
        driver.get("https://www.phptravels.net/");
        driver.manage().window().maximize();
        Thread.sleep(3000);


        driver.findElement(By.linkText("Flights")).click();
        Thread.sleep(2000);

  
        driver.findElement(By.xpath("//input[@value='oneway']")).click();
        Thread.sleep(1000);


        driver.findElement(By.xpath("//input[@id='autoFrom']")).clear();
        driver.findElement(By.xpath("//input[@id='autoFrom']")).sendKeys("Dubai");
        Thread.sleep(2000);
        driver.findElement(By.xpath("//ul[@id='ui-id-1']//li[1]")).click();
        Thread.sleep(1000);


        driver.findElement(By.xpath("//input[@id='autoTo']")).clear();
        driver.findElement(By.xpath("//input[@id='autoTo']")).sendKeys("London");
        Thread.sleep(2000);
        driver.findElement(By.xpath("//ul[@id='ui-id-2']//li[1]")).click();
        Thread.sleep(1000);


        driver.findElement(By.id("departureDate")).clear();
        driver.findElement(By.id("departureDate")).sendKeys("12/30/2025");
        Thread.sleep(1000);

 
        Select adults = new Select(driver.findElement(By.name("adults")));
        adults.selectByValue("1");
        Thread.sleep(1000);


        driver.findElement(By.xpath("//button[@id='searchFlights']")).click();
        Thread.sleep(5000);

  



        driver.findElement(By.xpath("(//a[contains(text(),'Book')])[1]")).click();
        Thread.sleep(3000);


        driver.findElement(By.name("first_name")).sendKeys("Ashish");
        Thread.sleep(1000);

        driver.findElement(By.name("last_name")).sendKeys("Choudhary");
        Thread.sleep(1000);

        driver.findElement(By.name("email")).sendKeys("ashish@gmail.com");
        Thread.sleep(1000);

        driver.findElement(By.name("phone")).sendKeys("9097826201");
        Thread.sleep(1000);


        driver.findElement(By.xpath("//button[@type='submit']")).click();
        Thread.sleep(3000);

        // STEP 12: Print Confirmation
        System.out.println("Booking Result: " + driver.getTitle());

        Thread.sleep(2000);
      driver.quit();
    }
}
